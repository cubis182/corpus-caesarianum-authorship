library(pspearman)
library(Kendall)
retrieve_combination_similarity <- function(combo, section_vectors) {
vectors <-section_vectors |> filter(title %in% combo) |> dplyr::select(-title, -path)
#Need a jitter value to avoid ties; NOT NECESSARY WITH KENDALL PACKAGE
amount_jitter <- 0.001
vec_a <- vectors[1,] |> t() |> as.vector() |> jitter(amount = amount_jitter)
vec_b <- vectors[2,] |> t() |> as.vector() |> jitter(amount = amount_jitter)
#If using Spearman, use approximation AS89 when the number of variables is under 1,290
return(spearman.test(vec_a, vec_b, alternative = "two.sided", approximation = "AS89")$estimate)
}
#Parameters:
#  character book: Name of commentary book. Valid values: "gallic _ 1", "gallic _ 2", etc.
#  tibble section_vectors: In this file, the variable stored in sectioned.gorman.vars is assumed
# double prop: The proportion of sections to sample from to save on computation; should be 1 in the final article
within.book.similarity <- function(book, section_vectors, rows) {
sub_section_vectors <- section_vectors %>%
filter(path == book) |>
slice_sample(n = rows)
#Use the columns if this to select
#combn(sectioned.gorman.vars |> filter(path == "african ") |> pull(title), 2)
combos <- combn(sub_section_vectors |> pull(title), 2)
similarities <- apply(X = combos, MARGIN = 2, FUN = retrieve_combination_similarity, sub_section_vectors)
return(similarities)
}
prop <- 0.25
african_scores <- within.book.similarity("gallic _ 2 ", sectioned.gorman.vars, 25)
hist(african_scores)
