#First, like Gorman, remove ones appearing in less than 20% of the corpus. For section-by-section, that's 134 / 5 = 27
#Recommended operation on the output of get_vars()
transpose_all_vars <- function(all_vars) {
all_vars <- all_vars |> mutate(title = as.factor(title))
all_vars <- pivot_wider(
all_vars,
names_from = pasted,
values_from = n,
values_fill = 0)
return(all_vars)
}
#Reduces output of transpose_all_vars to top n variables
select_top_variables <- function(all_vars, n) {
top_cols <- all_vars |>
dplyr::select(-title) |>
summarize(across(everything(), sum, na.rm = TRUE)) |>
pivot_longer(cols = everything(), names_to = "col_name", values_to = "total") |>
arrange(desc(total)) |>
slice_head(n = n) |>
pull(col_name)
all_vars_top_thousand <- all_vars |>
dplyr::select(any_of(top_cols)) |>
mutate(title = all_vars$title) |>
relocate(title, .before = 1)
}
