get_book <- function(string) {
split_str <- unlist(strsplit(string, "_"))
#We use gsub to ensure there are no spaces, might be unnecessary
gsub(" ", "", paste(split_str[1], split_str[2], sep = "_"))
}
rm(get_book())
rm(get_book
)
#modes: "title", "book", "section"
get_title_segment <- function(string, mode = "book") {
split_str <- unlist(strsplit(string, "_"))
#We use gsub to ensure there are no spaces, might be unnecessary
gsub(" ", "", paste(split_str[1], if (mode != "title") split_str[2], if (mode == "section") split_str[3], sep = "_"))
}
get_title_segment("amicitia_1_0")
get_title_segment("amicitia_1_0", "title")
#modes: "title", "book", "section"
get_title_segment <- function(string, mode = "book") {
split_str <- unlist(strsplit(string, "_"))
#We use gsub to ensure there are no spaces, might be unnecessary
gsub(" ", "", paste(
split_str[1],
if (mode != "title") paste("_", split_str[2]),
if (mode == "section") paste("_", split_str[3])
)
)
}
get_title_segment("amicitia_1_0", "title")
get_title_segment("amicitia_1_0", "book")
get_title_segment("amicitia_1_0", "section")
#modes: "title", "book", "section"
