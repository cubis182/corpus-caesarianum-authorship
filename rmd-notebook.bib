	pages = {951--962},
	file = {Full Text PDF:/Users/matthewdehass/Zotero/storage/PX7NYMHZ/Zhelezniak et al. - 2019 - Correlation Coefficients and Semantic Textual Similarity.pdf:application/pdf},
}

